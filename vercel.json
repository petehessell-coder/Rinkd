{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "create-react-app",
  "installCommand": "npm install",
  "buildCommand": "CI=false GENERATE_SOURCEMAP=false npm run build",
  "outputDirectory": "build",
  "rewrites": [
    { "source": "/g/:gameId", "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|Facebot|Twitterbot|Slackbot|Slack-ImgProxy|WhatsApp|Discordbot|LinkedInBot|TelegramBot|Pinterest|redditbot|Googlebot|bingbot|Applebot|Embedly|iframely|SkypeUriPreview|Mastodon|Bluesky|vkShare|nuzzel|Google-InspectionTool).*" }], "destination": "/api/unfurl?type=g&id=:gameId" },
    { "source": "/lg/:gameId", "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|Facebot|Twitterbot|Slackbot|Slack-ImgProxy|WhatsApp|Discordbot|LinkedInBot|TelegramBot|Pinterest|redditbot|Googlebot|bingbot|Applebot|Embedly|iframely|SkypeUriPreview|Mastodon|Bluesky|vkShare|nuzzel|Google-InspectionTool).*" }], "destination": "/api/unfurl?type=lg&id=:gameId" },
    { "source": "/league/:id", "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|Facebot|Twitterbot|Slackbot|Slack-ImgProxy|WhatsApp|Discordbot|LinkedInBot|TelegramBot|Pinterest|redditbot|Googlebot|bingbot|Applebot|Embedly|iframely|SkypeUriPreview|Mastodon|Bluesky|vkShare|nuzzel|Google-InspectionTool).*" }], "destination": "/api/unfurl?type=league&id=:id" },
    { "source": "/tournament/:id", "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(facebookexternalhit|Facebot|Twitterbot|Slackbot|Slack-ImgProxy|WhatsApp|Discordbot|LinkedInBot|TelegramBot|Pinterest|redditbot|Googlebot|bingbot|Applebot|Embedly|iframely|SkypeUriPreview|Mastodon|Bluesky|vkShare|nuzzel|Google-InspectionTool).*" }], "destination": "/api/unfurl?type=tournament&id=:id" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
